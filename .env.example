# ==============================================
# DTAI PROJECT MANAGER - ENVIRONMENT VARIABLES
# ==============================================

# Configuración del servidor
NODE_ENV=development
PORT=3000
APP_NAME=DTAI_PROJECT_MANAGER
APP_URL=http://localhost:3000

# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=GDP
DB_USER=root
DB_PASSWORD=diego1234
DB_DIALECT=mysql

# Configuración JWT
JWT_SECRET=your-super-secret-jwt-key-here-make-it-long-and-complex
JWT_EXPIRE=24h
JWT_REFRESH_SECRET=your-refresh-secret-key-here-also-make-it-long-and-complex
JWT_REFRESH_EXPIRE=7d

# Configuración de seguridad
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret-here-for-additional-security

# Configuración de email (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@dtai.com
FROM_NAME=DTAI_PROJECT_MANAGER

# Rate limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# File upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads/

# URLs del frontend (para CORS)
FRONTEND_URL=http://localhost:3001
ADMIN_URL=http://localhost:3002

# Configuración de usuarios por defecto
SUPER_ADMIN_EMAIL=admin@dtai.com
SUPER_ADMIN_PASSWORD=Admin123!

# Configuración de producción (comentadas por defecto)
# HTTPS_ENABLED=true
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem

# Configuración de monitoreo
# MONITORING_ENABLED=true
# SENTRY_DSN=your-sentry-dsn-here

# Configuración de Redis (para futuras features)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Configuración de almacenamiento en la nube
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=dtai-project-manager